{
	admin off
	auto_https off
}

:8080 {
	root * /srv
	encode zstd gzip

	header {
		defer
		-Server
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' {$CSP_CONNECT_SRC}; worker-src 'self'; object-src 'none'"
	}

	handle_errors {
		header {
			defer
			-Server
			X-Content-Type-Options "nosniff"
			Referrer-Policy "strict-origin-when-cross-origin"
			X-Frame-Options "DENY"
			Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
			Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' {$CSP_CONNECT_SRC}; worker-src 'self'; object-src 'none'"
		}
		respond "{http.error.status_code} {http.error.status_text}" {http.error.status_code}
	}

	@runtimeConfig path /config/runtime.json
	handle @runtimeConfig {
		header Cache-Control "no-store, max-age=0"
		file_server
	}

	@immutable path_regexp immutable ^/assets/.*-[A-Za-z0-9_-]{8,}\.(?:css|js|woff2?|png|svg)$
	@assetPath path /assets/* /mockServiceWorker.js
	handle @assetPath {
		header @immutable Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	@publicAsset path /icons.svg /favicon.ico
	handle @publicAsset {
		header Cache-Control "public, max-age=3600"
		file_server
	}

	handle {
		try_files {path} /index.html
		header Cache-Control "no-cache, no-store, must-revalidate"
		file_server
	}
}
