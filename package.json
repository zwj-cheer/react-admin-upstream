{
  "name": "react-admin-upstream",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=24 <26"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:changed": "vitest run --changed",
    "test:watch": "vitest",
    "e2e": "playwright test --project=e2e",
    "e2e:report": "playwright show-report",
    "visual": "playwright test --project=visual",
    "a11y": "playwright test --project=a11y",
    "check:architecture": "depcruise --config .dependency-cruiser.cjs src",
    "check:dead-code": "knip --no-progress --include files,dependencies,unlisted,unresolved",
    "verify:container": "node scripts/verify-container.mjs",
    "verify": "pnpm typecheck && pnpm lint && pnpm check:architecture && pnpm check:dead-code && pnpm test && pnpm build && node scripts/verify-template.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "i18next": "^26.3.6",
    "oidc-client-ts": "^3.3.0",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^17.0.10",
    "react-router": "^8.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.27.0",
    "lint-staged": "^17.0.8",
    "msw": "^2.12.7",
    "prettier": "^3.5.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.2.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.8"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
